{
  "name": "brawl-grade-bot",
  "version": "1.0.0",
  "description": "Discord bot for Brawl Stars grade roles based on highest trophies",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/app/startBot.ts",
    "build": "tsc",
    "start": "node dist/app/startBot.js",
    "test": "vitest",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "commands:deploy": "tsx src/app/registerCommands.ts"
  },
  "dependencies": {
    "discord.js": "^14.16.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.38.4",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.19.18",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.17.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.0",
    "vitest": "^2.1.8"
  }
}
